import React, { useState, useEffect } from 'react';

// Import components
import ApplicationForm from './components/application/ApplicationForm';
import Hero from './components/landing/Hero';
import Hook from './components/landing/Hook';
import Problem from './components/landing/Problem';
import Pillars from './components/landing/Pillars';
import BrandBanner from './components/landing/BrandBanner';
import SecondaryHero from './components/landing/SecondaryHero';
import Mastery from './components/landing/Mastery';
import Graph from './components/landing/Graph';
import Testimonials from './components/landing/Testimonials';
import WhoIsThisFor from './components/landing/WhoIsThisFor';
import About from './components/landing/About';
import FAQ from './components/landing/FAQ';
import FinalCTA from './components/landing/FinalCTA';
import Footer from './components/landing/Footer';

// Import data
import { faqs } from './data/faqs';
import { testimonials } from './data/testimonials';

export default function App() {
    const [currentPage, setCurrentPage] = useState('landing');
    const [openFaq, setOpenFaq] = useState(null);
    const [selectedTestimonial, setSelectedTestimonial] = useState(null);
    const [showSuccessPopup, setShowSuccessPopup] = useState(false);
    const [formData, setFormData] = useState({ name: '', phone: '', email: '' });

    useEffect(() => {
        const script = document.createElement('script');
        script.src = "https://cdn.tailwindcss.com";
        document.head.appendChild(script);
        window.scrollTo(0, 0);
    }, [currentPage]);

    const toggleFaq = (index) => {
        setOpenFaq(openFaq === index ? null : index);
    };

    const handleApplyClick = () => {
        setCurrentPage('apply');
        window.scrollTo(0, 0);
    };

    const handleFormSubmit = (e) => {
        e.preventDefault();
        const targetEmail = "dummy29@mailinator.com";
        const subject = encodeURIComponent(`New Application: ${formData.name}`);
        const body = encodeURIComponent(
            `Name: ${formData.name}\n` +
            `Phone: ${formData.phone}\n` +
            `Email: ${formData.email}`
        );
        window.location.href = `mailto:${targetEmail}?subject=${subject}&body=${body}`;
        setShowSuccessPopup(true);
    };

    const closeSuccessPopup = () => {
        setShowSuccessPopup(false);
        setFormData({ name: '', phone: '', email: '' });
        setCurrentPage('landing');
        window.scrollTo(0, 0);
    };

    if (currentPage === 'apply') {
        return (
            <ApplicationForm
                formData={formData}
                setFormData={setFormData}
                onFormSubmit={handleFormSubmit}
                showSuccessPopup={showSuccessPopup}
                closeSuccessPopup={closeSuccessPopup}
                onBackClick={() => setCurrentPage('landing')}
            />
        );
    }

    return (
        <div className="min-h-screen bg-[#efefec] text-[#2b2b2b] selection:bg-[#7b0323] selection:text-white" style={{ fontFamily: "'Inter', sans-serif" }}>
            <style>
                {`
                    className="flex items-center space-x-2 text-[#7b0323] font-bold hover:translate-x-[-4px] transition-transform"
                >
                    <ArrowLeft className="w-5 h-5" />
                    <span>Back to Website</span>
                </button>
            </div>

            <Section className="pt-8">
                <div className="bg-[#f7f5f2] rounded-[2.5rem] shadow-xl border border-[#2b2b2b]/5 overflow-hidden max-w-2xl mx-auto">
                    <div className="p-8 md:p-12 text-center bg-[#7b0323] text-white">
                        <h1 className="text-3xl md:text-4xl font-bold mb-4">Application Form</h1>
                        <p className="opacity-80">Tell us a bit about yourself to get started on your transformation journey.</p>
                    </div>

                    <form onSubmit={handleFormSubmit} className="p-8 md:p-12 space-y-6">
                        <div className="space-y-2">
                            <label className="text-sm font-bold uppercase tracking-wider text-[#2b2b2b]/60 ml-1">Full Name</label>
                            <input
                                required
                                type="text"
                                placeholder="Enter your name"
                                value={formData.name}
                                onChange={(e) => setFormData({ ...formData, name: e.target.value })}
                                className="w-full bg-[#efefec] border border-[#2b2b2b]/10 rounded-2xl px-6 py-4 outline-none focus:border-[#7b0323] transition-colors"
                            />
                        </div>

                        <div className="space-y-2">
                            <label className="text-sm font-bold uppercase tracking-wider text-[#2b2b2b]/60 ml-1">Phone Number</label>
                            <input
                                required
                                type="tel"
                                placeholder="+1 (555) 000-0000"
                                value={formData.phone}
                                onChange={(e) => setFormData({ ...formData, phone: e.target.value })}
                                className="w-full bg-[#efefec] border border-[#2b2b2b]/10 rounded-2xl px-6 py-4 outline-none focus:border-[#7b0323] transition-colors"
                            />
                        </div>

                        <div className="space-y-2">
                            <label className="text-sm font-bold uppercase tracking-wider text-[#2b2b2b]/60 ml-1">Email Address</label>
                            <input
                                required
                                type="email"
                                placeholder="name@example.com"
                                value={formData.email}
                                onChange={(e) => setFormData({ ...formData, email: e.target.value })}
                                className="w-full bg-[#efefec] border border-[#2b2b2b]/10 rounded-2xl px-6 py-4 outline-none focus:border-[#7b0323] transition-colors"
                            />
                        </div>

                        <div className="pt-4">
                            <button
                                type="submit"
                                className="w-full py-5 rounded-2xl bg-[#7b0323] text-white font-bold text-lg shadow-lg hover:shadow-xl hover:scale-[1.02] active:scale-95 transition-all flex items-center justify-center space-x-3"
                            >
                                <span>Submit Application</span>
                                <Send className="w-5 h-5" />
                            </button>
                        </div>
                    </form>
                </div>
            </Section>

            {/* Success Popup Modal */}
            {showSuccessPopup && (
                <div className="fixed inset-0 z-[200] flex items-center justify-center p-6 bg-[#2b2b2b]/60 backdrop-blur-sm animate-in fade-in duration-300">
                    <div className="bg-white rounded-[2rem] p-10 max-w-md w-full text-center shadow-2xl transform animate-in zoom-in slide-in-from-bottom-4 duration-300">
                        <div className="w-20 h-20 bg-green-100 text-green-600 rounded-full flex items-center justify-center mx-auto mb-6">
                            <CheckCircle2 className="w-12 h-12" />
                        </div>
                        <h2 className="text-3xl font-bold text-[#2b2b2b] mb-4">Thank You!</h2>
                        <p className="text-[#2b2b2b]/60 mb-8 leading-relaxed">
                            We have received your application. We will reach out to you soon to discuss your next steps!
                        </p>
                        <button
                            onClick={closeSuccessPopup}
                            className="w-full py-4 rounded-xl bg-[#7b0323] text-white font-bold shadow-lg hover:opacity-90 transition-all"
                        >
                            Back to Website
                        </button>
                    </div>
                </div>
            )}
        </div>
    );
}

// --- Main Landing Page View ---

return (
    <div className="min-h-screen bg-[#efefec] text-[#2b2b2b] selection:bg-[#7b0323] selection:text-white" style={{ fontFamily: "'Inter', sans-serif" }}>
        <style>
            {`
          @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

                .faq-content {
                    max - height: 0;
                overflow: hidden;
                transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.3s ease;
                opacity: 0;
          }

                .faq-content.open {
                    max - height: 400px;
                opacity: 1;
                padding-bottom: 1.5rem;
          }

                .faq-item {
                    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
          }

                .line-clamp-6 {
                    display: -webkit-box;
                -webkit-line-clamp: 6;
                -webkit-box-orient: vertical;
                overflow: hidden;
          }

                /* Infinite Scroll Animation */
                @keyframes scroll {
                    0 % { transform: translateX(0); }
            100% {transform: translateX(calc(-50%)); }
          }

                .animate-scroll {
                    display: flex;
                width: max-content;
                animation: scroll 40s linear infinite;
          }

                .animate-scroll.paused {
                    animation - play - state: paused;
          }

                .animate-scroll:hover {
                    animation - play - state: paused;
          }

                .modal-overlay {
                    animation: fadeIn 0.2s ease-out forwards;
          }

                .modal-content {
                    animation: slideUp 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
          }

                @keyframes fadeIn {
                    from {opacity: 0; }
                to {opacity: 1; }
          }

                @keyframes slideUp {
                    from {transform: translateY(20px) scale(0.95); opacity: 0; }
                to {transform: translateY(0) scale(1); opacity: 1; }
          }

                .testimonial-scroll::-webkit-scrollbar {
                    width: 4px;
          }
                .testimonial-scroll::-webkit-scrollbar-track {
                    background: transparent;
          }
                .testimonial-scroll::-webkit-scrollbar-thumb {
                    background: rgba(123, 3, 35, 0.2);
                border-radius: 10px;
          }
        `}
            </style>

            {/* Hero Section */}
            <Section className="pt-24">
                <div className="bg-[#f7f5f2] p-8 md:p-12 rounded-3xl shadow-sm border border-[#2b2b2b]/5 grid md:grid-cols-3 gap-12 items-center">
                    <div className="space-y-6 md:col-span-2 flex flex-col items-center md:items-start text-center md:text-left">
                        <h1 className="text-4xl md:text-6xl font-bold leading-tight text-[#2b2b2b]">
                            Transform Your Vision <br /> Into Reality
                        </h1>
                        <p className="text-lg opacity-80 max-w-xl">
                            Stop waiting for the perfect moment. Take the leap today and build the future you've always imagined with our proven roadmap.
                        </p>
                        <div className="pt-4 w-full flex justify-center md:justify-start">
                            <Button onClick={handleApplyClick}>Apply Now</Button>
                        </div>
                    </div>
                    <div className="md:col-span-1 w-full h-full flex items-center">
                        <ImageFrame
                            src="https://images.unsplash.com/photo-1497215728101-856f4ea42174?auto=format&fit=crop&w=600&q=80"
                            alt="Workspace"
                            className="h-64 md:h-full min-h-[250px] w-full"
                        />
                    </div>
                </div>
            </Section>

            {/* Hook Section */}
            <Section className="text-center pb-8 pt-0">
                <div className="max-w-2xl mx-auto space-y-4">
                    <p className="text-xl font-medium">
                        "A high impact 1:1 coaching program ready to eliminate stress, stop overthinking & perform at their highest level - personally & professionally."
                    </p>
                </div>
            </Section>

            {/* Problem Section */}
            <Section className="pb-8">
                <div className="bg-[#f7f5f2] p-8 md:p-12 rounded-3xl shadow-sm border border-[#2b2b2b]/5 grid md:grid-cols-3 gap-12 items-stretch">
                    <div className="order-2 md:order-1 md:col-span-1 flex items-stretch">
                        <ImageFrame
                            src="https://images.unsplash.com/photo-1517245386807-bb43f82c33c4?auto=format&fit=crop&w=800&q=80"
                            alt="Collaboration"
                            className="h-64 md:h-full w-full"
                        />
                    </div>
                    <div className="space-y-6 order-1 md:order-2 md:col-span-2 flex flex-col justify-center">
                        <div>
                            <h2 className="text-3xl font-bold mb-4">The Problem You're Facing</h2>
                            <p className="opacity-80 text-lg leading-relaxed mb-4">
                                Most people struggle because they lack a clear roadmap. They waste time on trial and error, feeling overwhelmed and stuck. It doesn't have to be this hard.
