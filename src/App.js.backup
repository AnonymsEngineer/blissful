                            <p className="opacity-80 text-lg leading-relaxed">
                                Our proven methodology cuts through the noise and provides you with direct, actionable steps to reach your goals faster.
                            </p>
                        </div>
                    </div>
                </div>
            </Section>

            {/* Pillars Section */}
            <Section className="pt-8 text-center">
                <h2 className="text-3xl font-bold mb-4" style={{ color: '#7b0323' }}>Let's Do It</h2>
                <p className="max-w-2xl mx-auto mb-10 text-lg opacity-80">
                    We have broken down the entire process into four simple, actionable pillars that guarantee success.
                </p>

                <div className="bg-[#f7f5f2] p-8 md:p-12 rounded-3xl shadow-sm border border-[#2b2b2b]/5">
                    <p className="text-left mb-8 opacity-70 leading-relaxed pl-4">
