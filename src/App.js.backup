                            <h3 className="text-xl font-bold mb-2">{item.title}</h3>
                            <p className="opacity-60 text-sm">Experience true freedom and automated growth as you master this specific phase.</p>
                        </div>
                    ))}
                </div>
            </Section>

            {/* Graph Section */}
            <Section className="py-24">
                <div className="text-center mb-16">
                    <div className="inline-block px-8 py-2 border border-[#2b2b2b]/20 rounded-full mb-4">
                        <h2 className="text-xl md:text-2xl font-bold">The Trajectory of Growth</h2>
                    </div>
                    <p className="opacity-60 max-w-xl mx-auto">Success isn't linear. It builds quietly before exploding into exponential impact.</p>
